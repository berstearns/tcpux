# tcpux deploy config — copy to deploy/.env and edit.
#   cp deploy/.env.example deploy/.env

# TCP binding (server) / dial target (worker+client)
TCPUX_HOST=127.0.0.1
TCPUX_PORT=9978

# Install root on the target instance. Both local and SSH deploys use this.
REMOTE_ROOT=/tmp/tcpux-deploy

# Python interpreter on the target.
PYTHON=python3

# ── Queue (server) deploy ──────────────────────────────────────
QUEUE_SESSION=tcpux-queue
QUEUE_WINDOW=queue
QUEUE_PANE_SERVER=tcpux-queue-server
QUEUE_PANE_STATE=tcpux-queue-state

# ── Worker deploy ──────────────────────────────────────────────
WORKER_SESSION=tcpux-worker
WORKER_WINDOW=worker
WORKER_NAME=worker1
WORKER_PANE_MAIN=tcpux-worker-main
WORKER_PANE_OBS=tcpux-worker-obs
