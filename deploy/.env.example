# tcpux deploy config — copy to deploy/.env and fill in.
#
#   cp deploy/.env.example deploy/.env
#
# This file is the template checked into the public repo. Keep it free of
# real ports, tokens, or anything host-specific. The actual deploy/.env is
# gitignored.

# ── Network ────────────────────────────────────────────────────
# Host the queue and admin bind to on the target instance.
TCPUX_HOST=0.0.0.0

# Pick two unused high ports on your target. Do NOT reuse values from
# other projects and do NOT commit them. They live only in deploy/.env.
TCPUX_PORT=
TCPUX_ADMIN_PORT=

# Shared admin token for the allowlist_server.py mutations (allow/block).
# Generate via: `openssl rand -hex 32`
TCPUX_ADMIN_TOKEN=

# ── Paths ──────────────────────────────────────────────────────
# Install root on the target instance.
REMOTE_ROOT=/root/tcpux

# Path to the live allowlist db on the target.
TCPUX_ALLOWLIST_DB=/root/tcpux/allowlist.json

# Path to the live shortcuts db on the target.
TCPUX_SHORTCUTS_DB=/root/tcpux/shortcuts.json

PYTHON=python3

# ── Queue (server) deploy ──────────────────────────────────────
QUEUE_SESSION=tcpux-queue
QUEUE_WINDOW=queue
QUEUE_PANE_SERVER=tcpux-queue-server
QUEUE_PANE_ADMIN=tcpux-queue-admin
QUEUE_PANE_STATE=tcpux-queue-state

# ── Worker deploy ──────────────────────────────────────────────
WORKER_SESSION=tcpux-worker
WORKER_WINDOW=worker
WORKER_NAME=worker1
WORKER_PANE_MAIN=tcpux-worker-main
WORKER_PANE_OBS=tcpux-worker-obs
