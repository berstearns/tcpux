# tcpux — per-role deploy config for a NON-root worker (e.g. claude-runner).
# cp .env.example .env and fill in.

TCPUX_PORT=
REMOTE_ROOT=/home/<user>/tcpux
PYTHON=python3

WORKER_SESSION=tcpux-worker
WORKER_WINDOW=worker
WORKER_NAME=<unique-per-worker>
WORKER_PANE_MAIN=tcpux-worker-main-<user>
WORKER_PANE_OBS=tcpux-worker-obs-<user>
